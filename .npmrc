# Block lifecycle scripts (preinstall/install/postinstall) by default.
# This is the primary vector for npm supply-chain worms (e.g. Shai-Hulud):
# a compromised package publishes a malicious version whose postinstall
# script exfiltrates tokens and re-publishes itself to other packages the
# victim maintains. Blocking scripts by default means a plain `npm install`
# never executes arbitrary code from the dependency tree.
#
# Packages that legitimately need their install script (currently just
# cypress, to fetch its binary) must be run explicitly, e.g.:
#   npx cypress install
ignore-scripts=true
